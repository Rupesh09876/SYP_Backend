{
  "name": "hams-backend",
  "version": "1.0.0",
  "description": "Hospital Appointment Management System Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev-cors": "nodemon server-simple.js",
    "db:setup": "mysql -u root -p < ../database/setup.sql",
    "test-cors": "curl http://localhost:5000/api/health",
    "db:generate": "drizzle-kit generate --config drizzle.config.js",
    "db:push": "drizzle-kit push --config drizzle.config.js"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.7",
    "express": "^4.21.2",
    "express-rate-limit": "^6.11.2",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.2",
    "pg": "^8.16.3",
    "resend": "^6.9.3",
    "twilio": "^5.13.0",
    "validator": "^13.15.23"
  },
  "devDependencies": {
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.7",
    "nodemon": "^3.0.1",
    "tsx": "^4.20.6"
  }
}
